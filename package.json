{
  "name": "opencode-langsmith-tracing",
  "version": "0.1.2",
  "description": "LangSmith tracing plugin for opencode — traces sessions, LLM calls, tool calls, reasoning, and context compaction. Trace taxonomy compatible with the official langsmith-claude-code-plugins.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "langsmith",
    "langsmith-tracing",
    "llm-tracing",
    "llm-observability",
    "tracing",
    "trace",
    "observability",
    "telemetry",
    "claude-code",
    "langchain",
    "runtree",
    "cost-tracking",
    "llm",
    "ai",
    "agent",
    "agentic",
    "typescript"
  ],
  "author": {
    "name": "Dramalf",
    "email": "dramalfcsc@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Dramalf/opencode-langsmith-tracing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dramalf/opencode-langsmith-tracing.git"
  },
  "bugs": {
    "url": "https://github.com/Dramalf/opencode-langsmith-tracing/issues"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "langsmith": "^0.5.18"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
